      "pop_size": 160,
      "es_population": 320,
      "top_k": 2,
      "seed": 42
    },
    "prior_std": 0.6,
    "posterior_scale_init": 0.08,
    "kl_weight": 0.02,
    "bnn_learning_rate": 0.006,
    "bnn_epochs": 64,
    "bnn_batch_size": 72,
    "bnn_validation_split": 0.2,
    "bnn_mc_samples": 24,
    "bnn_early_stopping_rounds": 12
  },
  "training": {
    "rounds": 3,
    "validation_split": 0.2,
    "seed": 42,
    "generator_mc_samples": 24,
    "fake_jitter_std": 0.2
  }
