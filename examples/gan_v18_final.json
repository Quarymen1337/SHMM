    "adversarial_weight": 0.06,
    "mape_weight": 0.12,
    "period_weights": [0.3, 1.4, 2.2, 8.5],
    "max_grad_norm": 1.5,
    "use_uncertainty_head": true,
    "nll_weight": 0.24,
    "aux_day28_weight": 0.45,
    "use_day28_aux_head": true
  },
  "discriminator": {
    "neat_config_path": "",
