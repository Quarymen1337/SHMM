{
  "dataset": {
    "data_path": "../data/processed/all_sources_strength_v16_full.csv",
    "components": [
      "cement",
      "sand",
      "gravel",
      "water",
      "plasticizer_kg",
      "fly_ash",
      "microsilica_kg",
      "source_synthetic",
      "source_boxcrete",
      "source_normal_concrete"
    ],
    "strength_by_day": {
      "1": "strength_1",
      "3": "strength_3",
      "7": "strength_7",
      "28": "strength_28"
    },
    "min_time": 1,
    "max_time": 28
  },
  "physics": {
    "cement_feature": "cement",
    "water_feature": "water",
    "add_log_time_feature": true,
